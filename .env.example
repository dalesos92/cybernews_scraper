# ── App ─────────────────────────────────────────────────────────────
APP_NAME=CyberNews Scraper
LOG_LEVEL=INFO
OUTPUT_DIR=output

# ── Database ─────────────────────────────────────────────────────────
DB_PATH=data/cybernews.db

# ── HTTP ─────────────────────────────────────────────────────────────
HTTP_TIMEOUT=30
HTTP_MAX_RETRIES=3
HTTP_USER_AGENT=Mozilla/5.0 (compatible; CyberNewsBot/1.0; +https://github.com/your-org/cybernews-scraper)

# ── Contenido ────────────────────────────────────────────────────────
# Número de noticias a seleccionar por mes
TOP_N=4
# Ventana de búsqueda (días hacia atrás)
LOOKBACK_DAYS=35

# ── SMTP (opcional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=CyberNews Bot <your@email.com>
# Destinatarios separados por coma
EMAIL_RECIPIENTS=dev-team@company.com,appsec@company.com

# ── Microsoft Teams (opcional) ───────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ── Slack (opcional) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── OpenAI (opcional, para resúmenes en español con IA) ──────────────
OPENAI_API_KEY=

# ── Google Drive / Apps Script (Propuesta B) ─────────────────────────
# Autenticación para subir archivos a Drive:
#   Opción 1 (recomendada): ejecuta una sola vez →  gcloud auth application-default login
#   Opción 2 (sin gcloud):  descarga SA key de GCP y apunta la ruta aquí
#   GOOGLE_SA_KEY_PATH=C:\secrets\cybernews-sa-key.json

# ID de la carpeta Google Drive donde Python sube HTML + JSON
# URL: https://drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_FOLDER_ID=

# ID del Google Sheet con la lista de destinatarios (lo usa Apps Script)
# URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEETS_RECIPIENTS_ID=

# Template a usar para el archivo HTML subido a Drive: a | b | c
GOOGLE_EMAIL_TEMPLATE=c

# URL del Web App de Apps Script (doPost endpoint).
# Se obtiene al desplegar: Implementar → Nueva implementación → Aplicación web
# Python llama a esta URL tras subir los archivos a Drive.
GOOGLE_APPSCRIPT_WEBHOOK_URL=

# Token de seguridad compartido entre Python y Apps Script.
# Generarlo en Apps Script ejecutando setupWebhookToken() y copiarlo aquí.
# Se verifica en cada llamada al endpoint — nunca se expone en el código.
GOOGLE_APPSCRIPT_TOKEN=

# ── Activar/desactivar fuentes ───────────────────────────────────────
ENABLE_HACKERNEWS=true
ENABLE_SECURITYWEEK=true
ENABLE_KASPERSKY=true
ENABLE_WELIVESECURITY=true
ENABLE_CYBERSECNEWS=false
