<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
  <!--[if mso]>
  <noscript>
    <xml><o:OfficeDocumentSettings>
      <o:PixelsPerInch>96</o:PixelsPerInch>
    </o:OfficeDocumentSettings></xml>
  </noscript>
  <![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#f4f4f4;
             font-family:Arial,Helvetica,sans-serif;-webkit-text-size-adjust:100%;">

  <!-- Wrapper -->
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
         style="background:#f4f4f4;padding:24px 0;">
    <tr>
      <td align="center" valign="top">

        <!-- Card container -->
        <table role="presentation" width="680" cellpadding="0" cellspacing="0"
               style="max-width:680px;background:#ffffff;border-radius:8px;
                      overflow:hidden;border:1px solid #dde3ec;">

          <!-- ── Header ─────────────────────────────────────────── -->
          <tr>
            <td style="background:#003B73;padding:28px 36px;">
              <h1 style="color:#ffffff;margin:0;font-size:20px;
                         font-weight:bold;line-height:1.3;">
                🔐 {{ subject }}
              </h1>
              <p style="color:#9ec3e6;margin:8px 0 0;font-size:13px;">
                Generado el {{ generated_at }} · Selección mensual automatizada
              </p>
            </td>
          </tr>

          <!-- ── Intro ──────────────────────────────────────────── -->
          <tr>
            <td style="padding:24px 36px 8px;">
              <p style="color:#333333;margin:0;font-size:15px;line-height:1.6;">
                A continuación las <strong>{{ top_n }} noticias más relevantes</strong>
                del mes en ciberseguridad, priorizadas por impacto en equipos
                de <em>desarrollo, AppSec y DevOps</em>.
              </p>
            </td>
          </tr>

          <!-- ── Noticias ───────────────────────────────────────── -->
          {% for r in items %}
          <tr>
            <td style="padding:10px 36px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                     style="background:#f5f8fd;border-left:4px solid #003B73;
                            border-radius:4px;padding:18px 20px;">
                <tr>
                  <td>
                    <!-- Título con badge de rank -->
                    <h2 style="margin:0 0 10px;font-size:16px;line-height:1.4;">
                      <span style="display:inline-block;background:#003B73;
                                   color:#ffffff;padding:2px 9px;
                                   border-radius:10px;font-size:12px;
                                   font-weight:bold;margin-right:8px;
                                   vertical-align:middle;">#{{ r.rank }}</span>
                      <a href="{{ r.item.url }}"
                         style="color:#003B73;text-decoration:none;
                                vertical-align:middle;">
                        {{ r.item.title }}
                      </a>
                    </h2>

                    <!-- Meta: fuente, fecha, score -->
                    <p style="margin:0 0 10px;color:#666666;font-size:13px;">
                      📰 <strong>{{ r.item.source_name }}</strong>
                      &nbsp;&middot;&nbsp;
                      📅 {{ r.item.published_at | date_es }}
                      &nbsp;&middot;&nbsp;
                      ⭐ {{ "%.1f" | format(r.score) }} pts
                    </p>

                    <!-- Keywords badges -->
                    {% if r.item.keywords_found %}
                    <p style="margin:0 0 10px;">
                      {% for kw in r.item.keywords_found[:6] %}
                      <span style="display:inline-block;background:#e8f0fe;
                                   color:#1a56db;padding:2px 8px;
                                   border-radius:10px;font-size:11px;
                                   margin:0 4px 4px 0;">{{ kw }}</span>
                      {% endfor %}
                    </p>
                    {% endif %}

                    <!-- Análisis estructurado -->
                    {% if r.item.insight %}
                    {% set ins = r.item.insight %}
                    <table style="width:100%;border-collapse:collapse;
                                  margin:0 0 14px;font-size:13px;">
                      <tr style="background:#eef4fb;">
                        <td style="padding:6px 10px;font-weight:bold;
                                   color:#003B73;width:130px;
                                   vertical-align:top;">🟠 Afectados</td>
                        <td style="padding:6px 10px;color:#333;">
                          {{ ins.afectados }}</td>
                      </tr>
                      <tr style="background:#ffffff;">
                        <td style="padding:6px 10px;font-weight:bold;
                                   color:#003B73;vertical-align:top;">
                          🔢 Cifras / CVEs</td>
                        <td style="padding:6px 10px;color:#333;
                                   font-family:monospace;">
                          {{ ins.cifras }}</td>
                      </tr>
                      <tr style="background:#eef4fb;">
                        <td style="padding:6px 10px;font-weight:bold;
                                   color:#003B73;vertical-align:top;">
                          💥 Qué pasó</td>
                        <td style="padding:6px 10px;color:#333;
                                   line-height:1.55;">
                          {{ ins.que_paso }}</td>
                      </tr>
                      <tr style="background:#ffffff;">
                        <td style="padding:6px 10px;font-weight:bold;
                                   color:#003B73;vertical-align:top;">
                          🛡️ Mitigación</td>
                        <td style="padding:6px 10px;color:#333;
                                   line-height:1.55;">
                          {{ ins.mitigacion }}</td>
                      </tr>
                      <tr style="background:#fffbea;">
                        <td style="padding:6px 10px;font-weight:bold;
                                   color:#7c5f00;vertical-align:top;">
                          💡 Insight dev</td>
                        <td style="padding:6px 10px;color:#5a4000;
                                   line-height:1.55;">
                          {{ ins.insight_dev }}</td>
                      </tr>
                    </table>
                    {% else %}
                    <p style="margin:0 0 12px;color:#333333;font-size:14px;
                               line-height:1.65;">
                      {{ r.item.summary_es or r.item.summary[:300] }}
                    </p>
                    {% endif %}

                    <!-- CTA -->
                    <a href="{{ r.item.url }}"
                       style="display:inline-block;background:#003B73;
                              color:#ffffff;padding:7px 18px;
                              border-radius:4px;font-size:13px;
                              text-decoration:none;font-weight:bold;">
                      Leer artículo →
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endfor %}

          <!-- ── Spacer ──────────────────────────────────────────── -->
          <tr><td style="height:12px;"></td></tr>

          <!-- ── Footer ────────────────────────────────────────── -->
          <tr>
            <td style="padding:18px 36px;border-top:1px solid #e4e9f0;
                       background:#f9fafb;">
              <p style="color:#999999;font-size:12px;margin:0;
                        text-align:center;line-height:1.6;">
                Informe generado automáticamente por <strong>CyberNews Scraper</strong>.<br>
                Fuentes: The Hacker News · SecurityWeek · Kaspersky Securelist · WeLiveSecurity.<br>
                Para ajustar destinatarios o fuentes, edita el archivo <code>.env</code>.
              </p>
            </td>
          </tr>

        </table><!-- /Card container -->

      </td>
    </tr>
  </table><!-- /Wrapper -->

</body>
</html>
