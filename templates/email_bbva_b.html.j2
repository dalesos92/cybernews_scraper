<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
</head>
<!--
  TEMPLATE B — "Security Intelligence"
  Estilo: Header oscuro navy, cada noticia es una "ficha de amenaza" con nivel
  de severidad visual (badge de color), secciones destacadas en turquesa.
  Paleta: #000C88 (Navy) · #001490 (Blue) · #84C8FC (Turquoise) · #1B2A3B (card bg)
-->
<body style="margin:0;padding:0;background:#00072A;
             font-family:Arial,Helvetica,sans-serif;-webkit-text-size-adjust:100%;">

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
         style="background:#00072A;padding:28px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="680" cellpadding="0" cellspacing="0"
               style="max-width:680px;">

          <!-- ── Header ── -->
          <tr>
            <td style="background:#000C88;border-radius:8px 8px 0 0;
                       padding:0;overflow:hidden;">
              <!-- Banda turquesa superior -->
              <div style="height:4px;background:linear-gradient(90deg,#84C8FC,#001490);"></div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="padding:28px 36px 24px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td>
                          <img src="data:image/jpeg;base64," alt="BBVA" height="36" style="display:block;margin-bottom:12px;background:#ffffff;padding:5px 12px;border-radius:4px;" />
                          <h1 style="color:#84C8FC;margin:0 0 6px;font-size:15px;
                                     font-weight:bold;text-transform:uppercase;
                                     letter-spacing:1.5px;">
                            Security Intelligence Report
                          </h1>
                          <p style="color:#90C4F8;margin:0;font-size:13px;">
                            {{ subject }}
                          </p>
                        </td>
                        <td style="text-align:right;vertical-align:top;">
                          <!-- Indicador de estado del sistema -->
                          <div style="background:#081A4A;border:1px solid #84C8FC;
                                      border-radius:4px;padding:10px 14px;
                                      display:inline-block;">
                            <p style="color:#84C8FC;font-size:10px;margin:0 0 4px;
                                       text-transform:uppercase;letter-spacing:1px;">
                              Fecha
                            </p>
                            <p style="color:#ffffff;font-size:12px;font-weight:bold;
                                       margin:0;">
                              {{ generated_at }}
                            </p>
                          </div>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              <!-- Banda separadora turquesa inferior del header -->
              <div style="height:1px;background:#081A4A;margin:0 36px;"></div>
              <!-- Estadísticas rápidas -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="padding:14px 36px 18px;">
                    <p style="color:#3A5A98;font-size:12px;margin:0;">
                      <span style="color:#84C8FC;font-weight:bold;font-size:18px;">
                        {{ top_n }}
                      </span>&nbsp;amenazas críticas seleccionadas de fuentes
                      verificadas en español.
                      Priorizadas por impacto en plataformas de desarrollo y finanzas.
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ── Noticias ── -->
          {% for r in items %}
          {% set severity_color = "#E74C3C" if r.score >= 20 else ("#E67E22" if r.score >= 15 else "#F1C40F") %}
          {% set severity_label = "CRÍTICO" if r.score >= 20 else ("ALTO" if r.score >= 15 else "MEDIO") %}
          {% set severity_bg = "#2C0C0C" if r.score >= 20 else ("#2C1A08" if r.score >= 15 else "#2C2308") %}
          <tr>
            <td style="padding:{% if loop.first %}12px{% else %}6px{% endif %} 0 0;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                     style="background:#06101E;border:1px solid #0E2460;
                            border-radius:6px;overflow:hidden;">
                <tr>
                  <td style="padding:0;">

                    <!-- Cabecera de la ficha de amenaza -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                           style="background:#081828;border-bottom:1px solid #0E2460;">
                      <tr>
                        <td style="padding:12px 20px;vertical-align:middle;">
                          <!-- Número de rank -->
                          <span style="display:inline-block;
                                       background:#001490;color:#84C8FC;
                                       width:24px;height:24px;border-radius:50%;
                                       font-size:11px;font-weight:900;
                                       text-align:center;line-height:24px;
                                       margin-right:10px;vertical-align:middle;">
                            {{ r.rank }}
                          </span>
                          <a href="{{ r.item.url }}"
                             style="color:#EEF3FF;text-decoration:none;
                                    font-size:14px;font-weight:bold;
                                    line-height:1.4;vertical-align:middle;">
                            {{ r.item.title }}
                          </a>
                        </td>
                        <td style="padding:12px 20px;text-align:right;
                                   vertical-align:middle;white-space:nowrap;">
                          <!-- Badge de severidad -->
                          <span style="display:inline-block;
                                       background:{{ severity_bg }};
                                       color:{{ severity_color }};
                                       border:1px solid {{ severity_color }};
                                       padding:3px 10px;border-radius:3px;
                                       font-size:10px;font-weight:900;
                                       letter-spacing:1px;">
                            {{ severity_label }}
                          </span>
                        </td>
                      </tr>
                    </table>

                    <!-- Meta y keywords -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                           style="border-bottom:1px solid #0E2460;">
                      <tr>
                        <td style="padding:10px 20px;">
                          <p style="margin:0 0 8px;font-size:11.5px;">
                            <span style="background:#06182A;color:#70BCFC;
                                         padding:2px 8px;border-radius:3px;
                                         font-weight:bold;">
                              {{ r.item.source_name }}
                            </span>
                            <span style="color:#3A5A98;margin-left:8px;">
                              {{ r.item.published_at | date_es }}
                            </span>
                            <span style="color:#84C8FC;font-weight:bold;margin-left:8px;">
                              Score: {{ "%.1f" | format(r.score) }}
                            </span>
                          </p>
                          {% if r.item.keywords_found %}
                          <p style="margin:0;">
                            {% for kw in r.item.keywords_found[:6] %}
                            <span style="display:inline-block;
                                         background:#06182A;color:#90C4F8;
                                         border:1px solid #0E2C70;
                                         padding:1px 7px;border-radius:2px;
                                         font-size:10.5px;margin:0 3px 3px 0;
                                         font-family:monospace;">
                              {{ kw }}
                            </span>
                            {% endfor %}
                          </p>
                          {% endif %}
                        </td>
                      </tr>
                    </table>

                    <!-- Análisis en filas -->
                    {% if r.item.insight %}
                    {% set ins = r.item.insight %}
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding:14px 20px;border-bottom:1px solid #0E2460;">
                          <p style="color:#84C8FC;font-size:10px;font-weight:bold;
                                     text-transform:uppercase;letter-spacing:1px;margin:0 0 5px;">
                            ▸ Qué ocurrió
                          </p>
                          <p style="color:#C8D8F4;font-size:13px;margin:0;line-height:1.6;">
                            {{ ins.que_paso }}
                          </p>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:0;">
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                              <td style="padding:12px 20px;border-right:1px solid #0E2460;
                                         border-bottom:1px solid #0E2460;width:50%;
                                         vertical-align:top;">
                                <p style="color:#E67E22;font-size:10px;font-weight:bold;
                                           text-transform:uppercase;letter-spacing:1px;
                                           margin:0 0 4px;">
                                  ▸ Afectados
                                </p>
                                <p style="color:#C8D8F4;font-size:12.5px;margin:0;
                                           line-height:1.55;">
                                  {{ ins.afectados }}
                                </p>
                              </td>
                              <td style="padding:12px 20px;
                                         border-bottom:1px solid #0E2460;
                                         vertical-align:top;">
                                <p style="color:#E74C3C;font-size:10px;font-weight:bold;
                                           text-transform:uppercase;letter-spacing:1px;
                                           margin:0 0 4px;">
                                  ▸ CVEs / Cifras
                                </p>
                                <p style="color:#FF8A80;font-size:12px;margin:0;
                                           font-family:monospace;line-height:1.55;">
                                  {{ ins.cifras }}
                                </p>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                      <tr>
                        <td style="padding:0;">
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                              <td style="padding:12px 20px;border-right:1px solid #0E2460;
                                         width:50%;vertical-align:top;">
                                <p style="color:#84C8FC;font-size:10px;font-weight:bold;
                                           text-transform:uppercase;letter-spacing:1px;
                                           margin:0 0 4px;">
                                  ▸ Mitigación
                                </p>
                                <p style="color:#C8D8F4;font-size:12.5px;margin:0;
                                           line-height:1.55;">
                                  {{ ins.mitigacion }}
                                </p>
                              </td>
                              <td style="padding:12px 20px;vertical-align:top;
                                         background:#060F1A;">
                                <p style="color:#4CAF50;font-size:10px;font-weight:bold;
                                           text-transform:uppercase;letter-spacing:1px;
                                           margin:0 0 4px;">
                                  ▸ Acción recomendada
                                </p>
                                <p style="color:#A8D5A2;font-size:12.5px;margin:0;
                                           line-height:1.55;">
                                  {{ ins.insight_dev }}
                                </p>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                    {% else %}
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="padding:14px 20px;">
                          <p style="color:#C8D8F4;font-size:13px;margin:0;line-height:1.6;">
                            {{ r.item.summary_es or r.item.summary }}
                          </p>
                        </td>
                      </tr>
                    </table>
                    {% endif %}

                    <!-- CTA -->
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                           style="background:#060F1A;border-top:1px solid #0E2460;">
                      <tr>
                        <td style="padding:10px 20px;">
                          <a href="{{ r.item.url }}"
                             style="display:inline-block;background:#84C8FC;
                                    color:#000C88;padding:6px 18px;
                                    border-radius:3px;font-size:11.5px;
                                    text-decoration:none;font-weight:900;
                                    letter-spacing:0.5px;">
                            ACCEDER AL INFORME →
                          </a>
                        </td>
                        <td style="text-align:right;padding:10px 20px;">
                          <span style="color:#2A4A88;font-size:10.5px;">
                            {{ r.item.source_name }}
                          </span>
                        </td>
                      </tr>
                    </table>

                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {% endfor %}

          <!-- ── Ver más ── -->
          <tr>
            <td style="padding:16px 0;text-align:center;">
              <a href="remaining_news.html"
                 style="display:inline-block;background:transparent;
                        color:#84C8FC;border:1px solid #84C8FC;
                        padding:9px 28px;border-radius:4px;
                        font-size:12px;text-decoration:none;font-weight:bold;
                        letter-spacing:0.5px;">
                VER TODAS LAS NOTICIAS RECOPILADAS
              </a>
            </td>
          </tr>

          <!-- ── Footer ── -->
          <tr>
            <td style="background:#000820;border-radius:0 0 8px 8px;
                       padding:16px 36px;">
              <div style="height:1px;background:#0E2460;margin-bottom:14px;"></div>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td>
                    <p style="color:#2A4A88;font-size:11px;margin:0;line-height:1.7;">
                      <img src="data:image/jpeg;base64," alt="BBVA" height="18" style="vertical-align:middle;" />
                      &nbsp;·&nbsp; Ciberseguridad &amp; Inteligencia de Amenazas<br>
                      Informe automatizado. Fuentes en español verificadas manualmente.
                    </p>
                  </td>
                  <td style="text-align:right;vertical-align:middle;">
                    <span style="color:#0E2C70;font-size:10px;">
                      CyberNews Scraper
                    </span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
